# =========================================================================
# .gitignore — Mr-Dave / Hey, Teacher!
# =========================================================================

# ---- Secrets e variáveis de ambiente ----
.env
.env.*
!.env.example
*.pem
*.key
*.p12
secrets.json
credentials.json

# ---- Supabase (CLI gera esses arquivos localmente) ----
.supabase/
supabase/.branches/
supabase/.temp/

# ---- Sistema operacional ----
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
ehthumbs.db

# ---- Editores / IDEs ----
.vscode/
.idea/
*.swp
*.swo
*~
.history/

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Dependências (caso adicione build em JS no futuro) ----
node_modules/
dist/
build/
.cache/

# ---- Arquivos temporários do projeto ----
*.tmp
*.bak
*.orig

# ---- OneDrive / Backup local ----
*.lnk
